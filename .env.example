# hCaptcha Challenger - Environment Variables Example

# [REQUIRED] Google Gemini API Key
# Create API Key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# == Directory Settings ==
# cache_dir=tmp/.cache
# challenge_dir=tmp/.challenge
# captcha_response_dir=tmp/.captcha

# == Agent Behavior ==
# DISABLE_BEZIER_TRAJECTORY=False
# DISABLE_HSW_REVERSE=False
# RETRY_ON_FAILURE=True
# MAX_CRUMB_COUNT=2
# enable_challenger_debug=False

# == Timeouts (seconds/milliseconds) ==
# EXECUTION_TIMEOUT=120
# RESPONSE_TIMEOUT=30
# WAIT_FOR_CHALLENGE_VIEW_TO_RENDER_MS=1500

# == Model Selection ==
# Supported models: gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash-preview, etc.
# CHALLENGE_CLASSIFIER_MODEL=gemini-2.5-flash
# IMAGE_CLASSIFIER_MODEL=gemini-2.5-pro
# SPATIAL_POINT_REASONER_MODEL=gemini-2.5-pro
# SPATIAL_PATH_REASONER_MODEL=gemini-2.5-pro

# == Granular Model Selection ==
# IMAGE_DRAG_SINGLE_MODEL=
# IMAGE_DRAG_MULTI_MODEL=
# IMAGE_LABEL_SINGLE_SELECT_MODEL=
# IMAGE_LABEL_MULTI_SELECT_MODEL=

# == Skills & Updates ==
# custom_skills_path=
# enable_skills_update=False
# skills_update_repo=QIN2DIM/hcaptcha-challenger
# skills_update_branch=main

# == Ignore Settings ==
# ignore_request_types=[]
# ignore_request_questions=[]
